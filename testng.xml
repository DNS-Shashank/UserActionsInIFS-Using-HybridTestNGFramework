<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="IFS User Actions Test Suite">
    <!-- Register TestListener for ExtentReports generation -->
    <listeners>
        <listener class-name="com.useractionsinifs.testComponents.listeners.TestListener"/>
    </listeners>
    
    <test name="Login Tests">
        <groups>
            <run>
                <include name="login"/>
            </run>
        </groups>
        <classes>
            <class name="com.useractionsinifs.testCases.LoginTests"/>
        </classes>
    </test>
    
    <!-- Old smoke test configuration - commented out
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.useractionsinifs.testCases.UserCreationTest"/>
            <class name="com.useractionsinifs.testCases.UserPasswordResetTest"/>
            <class name="com.useractionsinifs.testCases.UserDeletionTest"/>
        </classes>
    </test>
    -->
    
    <!-- New smoke test configuration - class-level filtering -->
    <test name="Smoke Tests">
        <classes>
            <class name="com.useractionsinifs.testCases.UserCreationTest">
                <methods>
                    <include name="createUserTest"/>
                </methods>
            </class>
            <class name="com.useractionsinifs.testCases.UserPasswordResetTest"/>
            <class name="com.useractionsinifs.testCases.UserDeletionTest">
                <methods>
                    <include name="deleteUserTest"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.useractionsinifs.testCases.UserCreationTest"/>
            <class name="com.useractionsinifs.testCases.UserEnableDisableTest"/>
            <class name="com.useractionsinifs.testCases.UserSecurityRolesTest"/>
            <class name="com.useractionsinifs.testCases.UserCopyTest"/>
            <class name="com.useractionsinifs.testCases.UserImportExportTest"/>
            <class name="com.useractionsinifs.testCases.UserDeletionTest"/>
        </classes>
    </test>
</suite>
